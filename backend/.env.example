# ==========================================
# CHRONICLES BACKEND - ENVIRONMENT VARIABLES
# ==========================================

# ------------------------------------------
# APPLICATION
# ------------------------------------------
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ------------------------------------------
# DATABASE (Prisma)
# ------------------------------------------
DATABASE_URL=mysql://blog_user:blog_password@localhost:3306/blog_db

# ------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------
JWT_ACCESS_SECRET=your-access-secret-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------
# EMAIL (SMTP) — Password Reset
# ------------------------------------------
# For development: Use a Gmail App Password
# (Requires 2FA enabled on your Google account)
# https://myaccount.google.com/apppasswords
#
# For production: Use SendGrid, Resend, or AWS SES
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Chronicles <noreply@chronicles.dev>"

# ------------------------------------------
# FIREBASE ADMIN (Social Auth)
# ------------------------------------------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"
