# ==========================================
# MULTI-SERVICE BLOG DEPLOYMENT - ENV EXAMPLE
# ==========================================

# ------------------------------------------
# FRONTEND CONFIGURATION
# ------------------------------------------
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME="Multi-Service Blog"

# ------------------------------------------
# BACKEND CONFIGURATION
# ------------------------------------------
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# JWT Secrets
JWT_SECRET=super_secret_jwt_key_example
JWT_EXPIRES_IN=7d

# ------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------
DB_HOST=database
DB_PORT=3306
DB_USER=blog_user
DB_PASSWORD=blog_password_example
DB_NAME=blog_db
DB_ROOT_PASSWORD=root_password_example

# ------------------------------------------
# DOCKER CONFIGURATION
# ------------------------------------------
COMPOSE_PROJECT_NAME=multi_service_blog
DOCKER_RESTART_POLICY=unless-stopped
