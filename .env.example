# ══════════════════════════════════════════════════════
# CHRONICLES — DOCKER COMPOSE ENVIRONMENT
# ══════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# This file is used by docker-compose.yml.
# NEVER commit the actual .env file.
# ══════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# COMPOSE INFRASTRUCTURE
# ──────────────────────────────────────────────
COMPOSE_PROJECT_NAME=chronicles
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# MYSQL DATABASE
# ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=chronicles_root_password
MYSQL_DATABASE=chronicles_db
MYSQL_USER=chronicles_user
MYSQL_PASSWORD=chronicles_password

# ──────────────────────────────────────────────
# BACKEND RUNTIME
# ──────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=5000

# Database URL (uses Compose DNS: mysql service name)
DATABASE_URL=mysql://chronicles_user:chronicles_password@mysql:3306/chronicles_db

# JWT Secrets (change in production!)
JWT_ACCESS_SECRET=your-access-secret-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (as seen by the backend for CORS)
FRONTEND_URL=http://localhost:3000

# SMTP (Password Reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Chronicles <noreply@chronicles.dev>"

# Firebase Admin SDK (backend-only secrets)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"

# ──────────────────────────────────────────────
# FRONTEND BUILD-TIME (browser-safe values only)
# ──────────────────────────────────────────────
VITE_API_URL=/api
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
